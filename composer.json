{
    "name": "jooservices/laravel-chat-gateway",
    "description": "Laravel-first multi-provider chat gateway for Telegram, Viber, and WhatsApp.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "illuminate/cache": "^12.0",
        "illuminate/contracts": "^12.0",
        "illuminate/database": "^12.0",
        "illuminate/events": "^12.0",
        "illuminate/http": "^12.0",
        "illuminate/queue": "^12.0",
        "illuminate/routing": "^12.0",
        "illuminate/support": "^12.0",
        "illuminate/validation": "^12.0",
        "jooservices/client": "^1.0",
        "jooservices/dto": "^1.0",
        "jooservices/laravel-controller": "^1.0",
        "jooservices/laravel-events": "^1.0",
        "jooservices/laravel-repository": "^1.0",
        "mongodb/laravel-mongodb": "^5.5"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.19",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^10.0",
        "phpmd/phpmd": "^2.15",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.5",
        "squizlabs/php_codesniffer": "^3.10"
    },
    "autoload": {
        "psr-4": {
            "JOOservices\\LaravelChatGateway\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JOOservices\\LaravelChatGateway\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "JOOservices\\LaravelChatGateway\\LaravelChatGatewayServiceProvider"
            ],
            "aliases": {
                "ChatGateway": "JOOservices\\LaravelChatGateway\\Facades\\ChatGateway"
            }
        }
    },
    "scripts": {
        "lint": [
            "@lint:pint",
            "@lint:phpstan"
        ],
        "lint:all": [
            "@lint:pint:test",
            "@lint:phpstan",
            "@lint:phpcs",
            "@lint:phpmd"
        ],
        "lint:fix": [
            "@lint:pint"
        ],
        "lint:pint": "vendor/bin/pint",
        "lint:pint:test": "vendor/bin/pint --test",
        "lint:phpstan": "vendor/bin/phpstan analyse --memory-limit=1G",
        "lint:phpcs": "vendor/bin/phpcs",
        "lint:phpmd": "php -d error_reporting='E_ALL & ~E_DEPRECATED & ~E_USER_DEPRECATED' vendor/bin/phpmd src,tests text phpmd.xml",
        "test": "vendor/bin/phpunit",
        "test:coverage": "vendor/bin/phpunit --coverage-text",
        "check": [
            "@lint:all",
            "@test"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}